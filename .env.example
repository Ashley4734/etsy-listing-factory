# Required in production
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://your-domain.com
DATA_DIR=/app/data
UPLOAD_MAX_MB=50

# AI generation. Leave blank to use built-in template mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Basic password gate. Set this before exposing publicly.
APP_USERNAME=admin
APP_PASSWORD=change-me-now
SESSION_SECRET=replace-with-a-long-random-string

# Optional Etsy integration placeholders for a future draft-push workflow.
# The current MVP exports Etsy-ready content and listing assets.
ETSY_CLIENT_ID=
ETSY_SHOP_ID=
ETSY_REDIRECT_URI=https://your-domain.com/api/etsy/callback
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
